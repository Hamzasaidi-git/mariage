# Configuration de l'API Backend
VITE_API_URL=http://localhost:5000/api

# Configuration de l'application
VITE_APP_NAME="Annuaire Mariage Tunisie"
VITE_APP_DESCRIPTION="Trouvez les meilleurs prestataires pour votre mariage en Tunisie"
VITE_APP_VERSION=1.0.0

# Configuration pour la production (exemple)
# VITE_API_URL=https://votre-api.com/api

# Configuration des médias sociaux (optionnel)
VITE_FACEBOOK_URL=https://facebook.com/mariagetunsie
VITE_INSTAGRAM_URL=https://instagram.com/mariagetunsie
VITE_TWITTER_URL=https://twitter.com/mariagetunsie

# Configuration du contact
VITE_CONTACT_EMAIL=contact@mariage-tunisie.com
VITE_CONTACT_PHONE=+216 98 123 456
VITE_CONTACT_ADDRESS="Tunis, Tunisie"

# Configuration des uploads (optionnel)
VITE_MAX_FILE_SIZE=5242880  # 5MB en bytes
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/jpg,image/png,image/webp

# Mode développement/production
# VITE_NODE_ENV=development

# Configuration analytics (optionnel)
# VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Configuration email (optionnel)
# VITE_EMAILJS_SERVICE_ID=your-service-id
# VITE_EMAILJS_TEMPLATE_ID=your-template-id
# VITE_EMAILJS_PUBLIC_KEY=your-public-key