// Schéma Prisma pour l'annuaire de services de mariage
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String        @id @default(uuid())
  nom         String        @unique @db.VarChar(100)
  description String?       @db.Text
  icon        String?       @db.VarChar(50)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  // Relations
  prestataires Prestataire[]
  
  @@map("categories")
}

model Prestataire {
  id          String   @id @default(uuid())
  nom         String   @db.VarChar(150)
  description String   @db.Text
  adresse     String?  @db.VarChar(255)
  ville       String   @db.VarChar(100)
  tel         String?  @db.VarChar(20)
  whatsapp    String?  @db.VarChar(20)
  instagram   String?  @db.VarChar(100)
  email       String?  @db.VarChar(150)
  site_web    String?  @db.VarChar(255)
  prix_moyen  Float?
  note        Float?   @default(0)
  nombre_avis Int?     @default(0)
  images      Json?    // Array d'URLs d'images
  services    Json?    // Array de services proposés
  horaires    Json?    // Horaires d'ouverture
  actif       Boolean  @default(true)
  featured    Boolean  @default(false) // Prestataires mis en avant
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  userId     String?  @unique
  user       User?    @relation(fields: [userId], references: [id])
  messages   Message[]
  avis       Avis[]
  
  @@map("prestataires")
}

model User {
  id          String    @id @default(uuid())
  nom         String    @db.VarChar(100)
  email       String    @unique @db.VarChar(150)
  password    String    @db.VarChar(255)
  role        Role      @default(CLIENT)
  tel         String?   @db.VarChar(20)
  actif       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  prestataire Prestataire?
  messages    Message[]
  avis        Avis[]
  
  @@map("users")
}

model Message {
  id            String      @id @default(uuid())
  nom           String      @db.VarChar(100)
  email         String      @db.VarChar(150)
  tel           String?     @db.VarChar(20)
  message       String      @db.Text
  date_event    DateTime?   // Date prévue de l'événement
  budget        Float?
  lu            Boolean     @default(false)
  createdAt     DateTime    @default(now())
  
  // Relations
  prestataireId String
  prestataire   Prestataire @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  
  @@map("messages")
}

model Avis {
  id            String      @id @default(uuid())
  note          Int         // Note sur 5
  commentaire   String?     @db.Text
  nom_client    String      @db.VarChar(100)
  createdAt     DateTime    @default(now())
  
  // Relations
  prestataireId String
  prestataire   Prestataire @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  
  @@map("avis")
}

enum Role {
  ADMIN
  PRESTATAIRE
  CLIENT
}